{
  "name": "@repo/shared-kernel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./infrastructure/*.js": {
      "types": "./dist/infrastructure/*.d.ts",
      "default": "./dist/infrastructure/*.js"
    },
    "./infrastructure/services/*.js": {
      "types": "./dist/infrastructure/services/*.d.ts",
      "default": "./dist/infrastructure/services/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "typescript": "5.9.2"
  }
}
